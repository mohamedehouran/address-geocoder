# Input File Configuration [Required]
INPUT_FILENAME=input                                                # String: Name of the input file (without extension)
INPUT_FILE_FORMAT=CSV                                               # String: Input file type (CSV or PARQUET)

# API Key [Required]
OPENCAGE_API_KEY=xxxxxxxxxxxxxxxxxxxx                               # String: OpenCage API Key

# IRIS Geocoding [Optional]
IRIS_GEOCODING=True                                                 # Boolean: Indicate your will to add IRIS geocoding (True or False)

# Data Processing
MAX_WORKERS=4                                                       # Integer: Number of parallel workers for data processing. Defaut : Number of CPU cores - 1
CHUNKSIZE=100                                                       # Integer: Number of rows to process per batch. Default: 100